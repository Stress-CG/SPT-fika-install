Meta.MinAMPVersion=2.6.3.0
Meta.SpecificDockerImage=ghcr.io/stress-cg/fika-headless:latest
Meta.DockerRequired=True
Meta.DockerBaseReadOnly=False
Meta.ContainerPolicy=RecommendedOnLinux
Meta.ContainerPolicyReason=Runs the Windows EFT client under Wine. The container image provides Wine, Xvfb and Mesa software rendering, so no GPU or host dependencies are required.
